# Secrets for the SolarFlow MQTT Watchdog app.
# Copy this file to your AppDaemon secrets.yaml (usually at
# <appdaemon>/secrets.yaml) and fill in the values.
#
# These are NOT stored in apps.yaml to avoid committing credentials.

solarflow_ip:     "192.168.x.x"     # LAN IP of the SolarFlow device
solarflow_serial: "XXXXXXXXXXX"     # Device serial number (e.g. HEC4NENCN492140)
mqtt_broker_ip:   "192.168.x.x"     # LAN IP of the MQTT broker (usually = HA host)
mqtt_username:    "your_mqtt_user"
mqtt_password:    "your_mqtt_password"
