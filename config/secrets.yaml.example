# Copy this file to secrets.yaml and fill in your values.
# secrets.yaml is .gitignored and must NOT be committed.

solarflow_ip:     "192.168.x.x"   # LAN IP of the SolarFlow device
solarflow_serial: "XXXXXXXXXXX"   # Device serial (e.g. HEC4NENCN492140)
mqtt_broker_ip:   "192.168.x.x"   # LAN IP of the Mosquitto broker (= HA host)
mqtt_username:    "mqtt"
mqtt_password:    "mqtt"
